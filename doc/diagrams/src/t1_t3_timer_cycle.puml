@startuml
hide footbox

skinparam backgroundColor transparent
skinparam shadowing false
skinparam ArrowColor #5a7088
skinparam SequenceLifeLineBorderColor #5a7088
skinparam SequenceLifeLineBackgroundColor #f7fbff
skinparam ParticipantBorderColor #4d6a86
skinparam ParticipantBackgroundColor #f7fbff
skinparam ParticipantFontColor #1f2f3d
skinparam NoteBorderColor #96a7b8
skinparam NoteBackgroundColor #fffdf3

participant Primary as P
participant Secondary as S

== Normal cycle ==

P -> S: I-frame (P=1)
note left: T1 starts

S --> P: RR (F=1)
note left: T1 stops\nT3 starts

... idle ...

note left of P: T3 expires\nneed_p = true

P -> S: RR (P=1)
note left: T3 stops\nT1 starts

S --> P: RR (F=1)
note left: T1 stops\nT3 starts

== T1 expiry ==

P -> S: I-frame (P=1)
note left: T1 starts

P ->x S: (no response)
note left of P: T1 expires\nN2++, need_p = true

P -> S: RR (P=1)
note left: T1 restarts

S --> P: RR (F=1)
note left: T1 stops\nT3 starts\ncheckpoint retransmit

@enduml
