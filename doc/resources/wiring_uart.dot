digraph uart_loopback {
  rankdir=LR;
  bgcolor="transparent";
  node [shape=record, fontname="Helvetica", fontsize=11];
  edge [fontname="Helvetica", fontsize=10, penwidth=1.5];

  label="UART Loopback Wiring — NUCLEO-G474RE";
  labelloc=t;
  fontname="Helvetica";
  fontsize=13;

  usart1 [label="<tx> PA9  — USART1_TX | <rx> PA10 — USART1_RX"
          xlabel="Endpoint A\n(Primary)"];

  usart3 [label="<rx> PC11 — USART3_RX | <tx> PC10 — USART3_TX"
          xlabel="Endpoint B\n(Secondary)"];

  usart1:tx -> usart3:rx [color="#2196F3", label="TX → RX"];
  usart3:tx -> usart1:rx [color="#F44336", label="TX → RX"];
}
