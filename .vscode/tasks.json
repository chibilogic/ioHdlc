{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build_linux_tests",
            "type": "shell",
            "command": "make",
            "options": {
                "cwd": "${workspaceFolder}/tests/linux"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": ["$gcc"],
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "showReuseMessage": true,
                "clear": false
            }
        },
        {
            "label": "clean_linux_tests",
            "type": "shell",
            "command": "make clean",
            "options": {
                "cwd": "${workspaceFolder}/tests/linux"
            },
            "problemMatcher": []
        },
        {
            "label": "run_linux_tests",
            "type": "shell",
            "command": "make test",
            "options": {
                "cwd": "${workspaceFolder}/tests/linux"
            },
            "problemMatcher": []
        }
    ]
}
