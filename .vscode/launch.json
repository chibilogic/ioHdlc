{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug test_basic_connection",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/tests/linux/build/bin/test_basic_connection",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}/tests/linux",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                },
                {
                    "description": "Set Disassembly Flavor to Intel",
                    "text": "-gdb-set disassembly-flavor intel",
                    "ignoreFailures": true
                }
            ],
            "preLaunchTask": "build_linux_tests",
            "miDebuggerPath": "/usr/bin/gdb"
        },
        {
            "name": "Debug test_basic_connection (no build)",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/tests/linux/build/bin/test_basic_connection",
